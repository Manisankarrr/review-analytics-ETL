# Aiven MySQL connection
# Create a free MySQL service at https://aiven.io (no credit card required).
# After it's running, the Aiven console "Overview" tab shows a connection
# string of the form: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Copy each piece into the variables below.

AIVEN_HOST=your-service-name.aivencloud.com
AIVEN_PORT=12691
AIVEN_DATABASE=defaultdb
AIVEN_USER=avnadmin
AIVEN_PASSWORD=your-aiven-password

# Optional: path to the CA certificate downloaded from the Aiven console
# (Overview tab -> "CA Certificate" -> download as ca.pem). If omitted, the
# connection is still encrypted but does not verify the server certificate.
AIVEN_SSL_CA_PATH=

# Google Play scraping
# The app id is the part after "id=" in a Google Play Store URL, e.g. for
# https://play.google.com/store/apps/details?id=com.spotify.music
# the app id is com.spotify.music. Comma-separate multiple app ids.
GOOGLE_PLAY_APP_ID=com.spotify.music

GOOGLE_PLAY_LANG=en
GOOGLE_PLAY_COUNTRY=us

# Number of reviews to extract per app, per run.
REVIEWS_PER_RUN=200


RAW_DATA_PATH=data/raw/raw_reviews.csv
PROCESSED_REVIEWS_PATH=data/processed/clean_reviews.csv
PROCESSED_KEYWORDS_PATH=data/processed/keywords.csv
ETL_STATS_PATH=data/processed/etl_stats.json

# API / Dashboard
API_BASE_URL=http://localhost:8000

LOG_LEVEL=INFO